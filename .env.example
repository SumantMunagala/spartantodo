# Supabase (get these from https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: Canvas API base URL (defaults to https://sjsu.instructure.com for sync)
# CANVAS_BASE_URL=https://sjsu.instructure.com

# Cron sync (server-side scheduled sync for all users). Keep secret.
# Get service role key from Supabase Dashboard → Project Settings → API → Project API keys
SUPABASE_SERVICE_ROLE_KEY=
# Required for /api/cron/sync when using Vercel Cron; set in Vercel env and pass as Authorization: Bearer <value>
CRON_SECRET=

# Enable Google provider in Supabase Auth (Authentication → Providers → Google)
# Set Site URL and Redirect URLs in Authentication → URL Configuration
